// FP8 KV-cache prefill path, split out of xe_fmha_fwd_prefill_kernel.cpp.in so
// the e4m3/e5m2 kernel instantiations (which fan out over is_local x is_causal)
// compile in their own translation unit and keep the peak compiler memory of
// the (bf16/fp16) paged prefill TU low.
#define SYCL_INTEL_TARGET 20

#include "sycl/kernels/flash_attention_v2/xe_fmha_fwd_prefill_runner.hpp"

namespace prefill {

template <>
void FmhaPrefillFp8Runner<@HEAD_DIM@>::operator()(const Arguments& params) const {
  using TileShapeQK = cute::Shape<cute::Int<@TILED_Q@>, cute::Int<@TILED_KV@>, cute::_32>;
  using TileShapePV = cute::Shape<cute::Int<@TILED_Q@>, cute::_32, cute::Int<@TILED_KV@>>;
  using TileShapeOutput = cute::Shape<cute::Int<@TILED_Q@>, cute::Int<@TILED_OUT@>>;
  using SubgroupLayoutQK =
      cute::Layout<cute::Shape<cute::Int<@NUM_SG@>, cute::_1, cute::_1>, cute::Stride<cute::_1, cute::_1, cute::_1>>;

  // FP8 KV cache: Q is bf16 or fp16, K/V cache are fp8 (e4m3 or e5m2). The
  // mainloop dequantizes K/V with the per-tensor k_scale/v_scale (Fp8KV path).
  TORCH_CHECK(params.is_e4m3 || params.is_e5m2, "FmhaPrefillFp8Runner requires an fp8 KV cache");
  TORCH_CHECK(
      params.softmax_sink_ptr == nullptr, "fp8 KV cache prefill does not support sink logits");
