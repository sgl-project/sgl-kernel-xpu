#define SYCL_INTEL_TARGET 20

#include "sycl/kernels/flash_attention_v2/xe_fmha_fwd_chunkprefill_runner.hpp"

namespace chunkprefill {
namespace {
using TileShapeQK = cute::Shape<cute::Int<@TILED_Q@>, cute::Int<@TILED_KV@>, cute::_32>;
using TileShapePV = cute::Shape<cute::Int<@TILED_Q@>, cute::_32, cute::Int<@TILED_KV@>>;
using TileShapeO = cute::Shape<cute::Int<@TILED_Q@>, cute::Int<@HEAD_DIM@>>;
using SubgroupLayout =
  cute::Layout<cute::Shape<cute::Int<@NUM_SG@>, cute::_1, cute::_1>, cute::Stride<cute::_1, cute::_1, cute::_1>>;
constexpr int PipelineStages = 2;

using DynamicPersistentScheduler = cutlass::fmha::kernel::XeFHMADynamicPresistentTileScheduler;

template <bool Causal, bool LocalMask, bool Sink>
using StandardConfig = prefill::FMHAConfig<
    Causal,
    LocalMask,
    Sink,
    TileShapeQK,
    TileShapePV,
    TileShapeO,
    SubgroupLayout,
    void,
    PipelineStages>;

template <class Scheduler>
void run_standard_config(const Arguments& params) {
  AT_DISPATCH_BOOL_NO_RETURN(params.page_table != nullptr, PagedKV, {
    AT_DISPATCH_BOOL_NO_RETURN(params.softmax_sink_ptr != nullptr, Sink, {
      if (params.is_causal) {
        StandardConfig<true, false, Sink>::template run<true, true, PagedKV, Scheduler>(params);
      } else {
        AT_DISPATCH_BOOL_NO_RETURN(
            params.is_local,
            LocalMask,
            StandardConfig<false, LocalMask, Sink>::template run<true, true, PagedKV, Scheduler>(params))
      }
    })
  })
}
}  // namespace

template <>
void FmhaChunkPrefillDynamicRunner<@HEAD_DIM@>::operator()(const Arguments& params) const {
  run_standard_config<DynamicPersistentScheduler>(params);
}

template struct FmhaChunkPrefillDynamicRunner<@HEAD_DIM@>;

}  // namespace chunkprefill
